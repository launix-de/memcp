# memcp daemon configuration
# One CLI argument per line. Lines starting with # are ignored.
# Run 'dpkg-reconfigure memcp' to reconfigure interactively.
# After editing, run: systemctl restart memcp

-data /var/lib/memcp
--root-password=admin

--api-port=4321

--mysql-port=3307
--mysql-socket=/run/memcp/memcp.sock
